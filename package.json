{
  "name": "flintwork",
  "version": "0.0.1",
  "description": "A hand-crafted design system with headless primitives, token-driven theming, and built-in accessibility.",
  "author": "Venkatesh Mukundan <vmvenkatesh78@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vmvenkatesh78/flintwork"
  },
  "keywords": [
    "design-system",
    "react",
    "components",
    "headless",
    "accessibility",
    "design-tokens",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./primitives": {
      "types": "./dist/primitives/index.d.ts",
      "import": "./dist/primitives/index.js",
      "require": "./dist/primitives/index.cjs"
    },
    "./styles": "./dist/styled/index.css",
    "./styles/button": "./dist/styled/button.css",
    "./tokens": "./dist/tokens/tokens.css",
    "./tokens/light": "./dist/tokens/light.css",
    "./tokens/dark": "./dist/tokens/dark.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build:tokens": "tsx src/scripts/build-tokens.ts",
    "build:lib": "tsup",
    "build:css": "mkdir -p dist/styled && cp src/styled/*.css dist/styled/",
    "build": "pnpm build:tokens && pnpm build:lib && pnpm build:css",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.3",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^28.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
