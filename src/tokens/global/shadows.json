{
  "$description": "Global shadow values for elevation levels.",
  "shadow": {
    "$type": "shadow",
    "none": { "$value": "none" },
    "sm":   { "$value": "0px 1px 2px 0px rgba(16, 24, 40, 0.05)" },
    "md":   { "$value": "0px 4px 8px -2px rgba(16, 24, 40, 0.1), 0px 2px 4px -2px rgba(16, 24, 40, 0.06)" },
    "lg":   { "$value": "0px 12px 16px -4px rgba(16, 24, 40, 0.08), 0px 4px 6px -2px rgba(16, 24, 40, 0.03)" },
    "xl":   { "$value": "0px 20px 24px -4px rgba(16, 24, 40, 0.08), 0px 8px 8px -4px rgba(16, 24, 40, 0.03)" }
  }
}
