{
  "dialog": {
    "overlay": {
      "bg": {
        "$value": "rgba(0, 0, 0, 0.5)"
      }
    },
    "title": {
      "fontWeight": {
        "$value": "{fontWeight.semibold}"
      },
      "fontSize": {
        "$value": "{fontSize.lg}"
      },
      "color": {
        "$value": "{color.text.primary}"
      }
    },
    "content-lg": {
      "maxWidth": {
        "$value": "720px"
      }
    },
    "description": {
