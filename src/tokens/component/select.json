{
  "select": {
    "trigger": {
      "bg": "{color.bg.primary}",
      "border-color": "{color.border.default}",
      "text": "{color.text.primary}",
      "radius": "{radii.md}",
      "padding-x": "{spacing.3}",
      "padding-y": "{spacing.2}",
      "font-size": "{typography.fontSize.sm}",
      "min-width": "180px"
    },
    "placeholder-text": "{color.text.tertiary}",
    "content": {
      "bg": "{color.bg.primary}",
      "border-color": "{color.border.default}",
      "radius": "{radii.lg}",
      "shadow": "{shadow.lg}",
      "padding": "{spacing.1}",
      "z-index": "{z-index.popover}"
    },
    "item": {
      "text": "{color.text.primary}",
      "bg-hover": "{color.bg.hover}",
      "bg-selected": "{color.bg.active}",
      "font-size": "{typography.fontSize.sm}",
      "padding-x": "{spacing.2}",
      "padding-y": "{spacing.1.5}",
      "radius": "{radii.sm}"
    }
  }
}
