{
  "button": {
    "md": {
      "paddingY": {
        "$value": "{spacing.2}"
      },
      "fontSize": {
        "$value": "{fontSize.sm}"
      },
      "paddingX": {
        "$value": "{spacing.4}"
      }
    },
    "primary": {
      "bg": {
        "$value": "{color.interactive.default}"
      },
      "border": {
        "$value": "transparent"
      },
      "bgActive": {
        "$value": "{color.interactive.active}"
      },
      "bgHover": {
        "$value": "{color.interactive.hover}"
      },
      "text": {
        "$value": "{color.text.inverse}"
      }
    },
    "ghost": {
      "bg": {
        "$value": "transparent"
      },
      "bgHover": {
        "$value": "{color.bg.hover}"
      },
      "text": {
        "$value": "{color.interactive.default}"
      },
      "border": {
        "$value": "transparent"
      },
      "bgActive": {
        "$value": "{color.bg.active}"
      }
    },
    "secondary": {
      "bgHover": {
        "$value": "{color.bg.hover}"
      },
      "border": {
        "$value": "{color.border.default}"
      },
      "bgActive": {
        "$value": "{color.bg.active}"
      },
      "bg": {
        "$value": "{color.bg.primary}"
      },
      "text": {
        "$value": "{color.text.primary}"
      }
    },
    "lg": {
      "paddingY": {
        "$value": "{spacing.3}"
      },
      "fontSize": {
        "$value": "{fontSize.md}"
      },
      "paddingX": {
        "$value": "{spacing.5}"
      }
    },
    "disabled": {
      "border": {
        "$value": "{color.border.disabled}"
      },
      "bg": {
        "$value": "{color.bg.disabled}"
      },
      "text": {
        "$value": "{color.text.disabled}"
      }
    },
    "sm": {
      "fontSize": {
        "$value": "{fontSize.xs}"
      },
      "paddingX": {
        "$value": "{spacing.3}"
      },
      "paddingY": {
        "$value": "{spacing.1}"
      }
    },
    "danger": {
      "bg": {
        "$value": "{color.red.500}"
      },
      "bgActive": {
        "$value": "{color.red.700}"
      },
      "text": {
        "$value": "{color.text.inverse}"
      },
      "border": {
        "$value": "transparent"
      },
      "bgHover": {
        "$value": "{color.red.600}"
      }
    },
    "borderRadius": {
      "$value": "{radii.md}"
    },
    "fontWeight": {
      "$value": "{fontWeight.medium}"
    },
    "focusRing": {
      "$value": "{color.border.focus}"
    }
  }
}
