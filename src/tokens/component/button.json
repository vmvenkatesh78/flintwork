{
  "$description": "Button component tokens — every style value references a semantic token. The button never touches global primitives directly.",
  "button": {
    "primary": {
      "bg":          { "$value": "{color.interactive.default}" },
      "bgHover":     { "$value": "{color.interactive.hover}" },
      "bgActive":    { "$value": "{color.interactive.active}" },
      "text":        { "$value": "{color.text.inverse}" },
      "border":      { "$value": "transparent" }
    },
    "secondary": {
      "bg":          { "$value": "transparent" },
      "bgHover":     { "$value": "{color.bg.hover}" },
      "bgActive":    { "$value": "{color.bg.active}" },
      "text":        { "$value": "{color.text.primary}" },
      "border":      { "$value": "{color.border.default}" }
    },
    "danger": {
      "bg":          { "$value": "{color.red.500}" },
      "bgHover":     { "$value": "{color.red.600}" },
      "bgActive":    { "$value": "{color.red.700}" },
      "text":        { "$value": "{color.text.inverse}" },
      "border":      { "$value": "transparent" }
    },
    "disabled": {
      "bg":          { "$value": "{color.bg.disabled}" },
      "text":        { "$value": "{color.text.disabled}" },
      "border":      { "$value": "{color.border.disabled}" }
    },
    "borderRadius":  { "$value": "{radii.md}" },
    "paddingX":      { "$value": "{spacing.4}" },
    "paddingY":      { "$value": "{spacing.2}" },
    "fontSize":      { "$value": "{fontSize.sm}" },
    "fontWeight":    { "$value": "{fontWeight.medium}" },
    "focusRing":     { "$value": "{color.border.focus}" }
  }
}
