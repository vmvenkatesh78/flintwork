{
  "$description": "Tabs component tokens.",
  "tabs": {
    "list": {
      "borderColor": { "$value": "{color.border.default}" },
      "gap":         { "$value": "{spacing.0}" }
    },
    "trigger": {
      "paddingX":       { "$value": "{spacing.4}" },
      "paddingY":       { "$value": "{spacing.2}" },
      "fontSize":       { "$value": "{fontSize.sm}" },
      "fontWeight":     { "$value": "{fontWeight.medium}" },
      "color":          { "$value": "{color.text.secondary}" },
      "colorActive":    { "$value": "{color.text.primary}" },
      "colorHover":     { "$value": "{color.text.primary}" },
      "colorDisabled":  { "$value": "{color.text.disabled}" },
      "borderColor":    { "$value": "transparent" },
      "borderActive":   { "$value": "{color.interactive.default}" }
    },
    "panel": {
      "paddingX": { "$value": "{spacing.4}" },
      "paddingY": { "$value": "{spacing.4}" }
    }
  }
}